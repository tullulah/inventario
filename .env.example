# Base de datos Neon (Postgres serverless)
# Obtén la connection string en: https://console.neon.tech
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Vercel Blob Storage
# Se genera automáticamente al crear el Blob store en Vercel
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# JWT para autenticación
JWT_SECRET=cambia-esto-por-un-secreto-seguro

# Servicio YOLO (opcional, solo para clasificación automática local)
# YOLO_SERVICE_URL=http://localhost:8000

# Puerto del servidor local
PORT=3001
